# Kredensial Supabase (Diperoleh dari dashboard Supabase -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key-here

# OpenRouter API Key (Diperoleh dari https://openrouter.ai)
# Digunakan untuk model gratis seperti google/gemini-2.0-flash-exp:free
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Resend API Key (Diperoleh dari dashboard Resend)
RESEND_API_KEY=re_your-resend-api-key-here

# Alamat email penerima notifikasi darurat (Gunakan email terdaftar Resend Anda untuk Sandbox)
ADMIN_ALERT_EMAIL=your-alert-email@domain.com

# URL domain aplikasi untuk tautan dashboard pada notifikasi email (misal: https://zulvikar.is-a.dev/synapse-cs)
NEXT_PUBLIC_APP_URL=http://localhost:3000/synapse-cs
